rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow users to access their own complete data tree
    match /users/{userId} {
      // User can read/write their base document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // User can read/write any subcollection inside their document
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
